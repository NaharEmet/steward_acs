# AUTH0_DOMAIN must match steward_acs AUTH0_* env vars.
# Authorize redirects use per-host audience https://{host}/mcp/sse (multi-tenant).
# Syncthing admin UI is not published here — use SSH tunnel or loopback only.

# OAuth routes for Auth0 MCP connector integration
(oauth_routes) {
    # Serve OAUTH authorization server metadata (Claude discovers endpoints here)
    @wk_oauth_auth path /.well-known/oauth-authorization-server*
    handle @wk_oauth_auth {
        header Content-Type "application/json"
        respond `{"issuer":"https://{$AUTH0_DOMAIN}/","authorization_endpoint":"https://{host}/authorize","token_endpoint":"https://{host}/token","registration_endpoint":"https://{host}/oidc/register","jwks_uri":"https://{$AUTH0_DOMAIN}/.well-known/jwks.json","response_types_supported":["code"],"response_modes_supported":["query"],"grant_types_supported":["authorization_code","refresh_token"],"scopes_supported":["mcp:tools"]}`
    }

    # Proxy OAuth token requests to Auth0's token endpoint
    @token {
        method POST
        path /token
    }
    handle @token {
        rewrite * /oauth/token
        reverse_proxy https://{$AUTH0_DOMAIN}
    }

    # Per-host audience must match ACS oauth-protected-resource metadata (multi-tenant).
    @authz path /authorize*
    handle @authz {
        redir https://{$AUTH0_DOMAIN}{path}?audience=https%3A%2F%2F{host}%2Fmcp%2Fsse&connection=email&{query}
    }

    # DCR: Dynamic Client Registration proxy to Auth0
    @dcr {
        method POST
        path /oidc/register
    }
    handle @dcr {
        rewrite * /oidc/register
        reverse_proxy https://{$AUTH0_DOMAIN}
    }
}

# Wildcard TLS — origin cert must cover *.{$BASE_DOMAIN}
{$BASE_DOMAIN} {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
    import oauth_routes
    reverse_proxy {$ACS_URL} {
        flush_interval -1
    }
}

*.{$BASE_DOMAIN} {
    tls /etc/caddy/certs/origin.pem /etc/caddy/certs/origin.key
    import oauth_routes
    reverse_proxy {$ACS_URL} {
        flush_interval -1
    }
}
