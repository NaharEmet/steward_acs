# Multi-tenant production deployment
# Copy to .env and fill in values before:
#   docker compose -f docker-compose.multitenant.yml up -d --build
# or (Cloudflare/prod):
#   docker compose -f docker-compose.cloudflare.yml up -d --build

# ─── Required ───────────────────────────────────────────────────────────────
BASE_DOMAIN=stewardacs.xyz
SECRET_KEY_BASE=
MCP_API_KEY=
ACS_USERNAME=admin
ACS_PASSWORD=

# Optional: bake a stable cookie signing salt into the release image at build time.
# COOKIE_SIGNING_SALT=

# ─── Multi-tenant ────────────────────────────────────────────────────────────
# MULTI_TENANT=true  # set in compose files
ACS_ORG_NAME=default  # existing org that keeps legacy memory paths and IDs

# ─── MCP / OAuth (optional — enable for Claude Connectors) ───────────────────
# MCP_QUERY_KEY_AUTH=true
# OAUTH_BEARER_ENABLED=false
# AUTH0_DOMAIN=
# AUTH0_AUDIENCE=
# MCP_PUBLIC_URL=https://prod.stewardacs.xyz
# MCP_RESOURCE_URL=https://prod.stewardacs.xyz/mcp/sse
# AUTH0_MGMT_CLIENT_ID=
# AUTH0_MGMT_CLIENT_SECRET=

# ─── Memory ─────────────────────────────────────────────────────────────────
# MEMORY_STORE=obsidian
# OBSIDIAN_VAULT_PATH=/vaults

# ─── Per-org Syncthing API keys ──────────────────────────────────────────────
# One container per org; each needs a unique STGUIAPIKEY.
# Generate in Syncthing GUI (Settings → API) after first boot, or set before deploy.
SYNCTHING_DEFAULT_API_KEY=
SYNCTHING_PROD_API_KEY=
SYNCTHING_FSGBHUTAN_API_KEY=
SYNCTHING_SAFETYCONNECT_API_KEY=

# Legacy apex Obsidian host (obsidian.<BASE_DOMAIN>) basic auth
SYNC_BCRYPT_PASS=

# ─── LLM providers (optional) ────────────────────────────────────────────────
# ENABLED_LLM_PROVIDERS=
# MIMO_API_KEY=
# NIM_API_KEY=
# MINIMAX_API_KEY=
# OPENAI_API_KEY=
