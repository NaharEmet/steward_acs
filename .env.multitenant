# Production multi-tenant deployment
# Copy to .env and fill in values before:
#   docker compose -f docker-compose.multitenant.yml up -d
# With Postgres instead of SQLite:
#   docker compose -f docker-compose.multitenant.yml -f docker-compose.postgres.yml up -d

# ─── Required ───────────────────────────────────────────────────────────────
BASE_DOMAIN=stewardacs.xyz
PHX_HOST=prod.stewardacs.xyz
SECRET_KEY_BASE=
MCP_API_KEY=

# Dashboard Auth0 Regular Web Application
ACCOUNT_HOST=stewardacs.xyz
OIDC_BROWSER_ENABLED=true
AUTH0_WEB_CLIENT_ID=
AUTH0_WEB_CLIENT_SECRET=
AUTH0_WEB_REDIRECT_URI=https://stewardacs.xyz/auth/callback
SELF_SERVICE_ORGS_ENABLED=true

# Image tag (default: multitenant)
ACS_IMAGE_TAG=multitenant

# ─── Multi-tenant ────────────────────────────────────────────────────────────
ACS_ORG_NAME=default

# ─── MCP / OAuth (optional — enable for Claude Connectors) ───────────────────
# MCP_QUERY_KEY_AUTH=true
# OAUTH_BEARER_ENABLED=false
# AUTH0_DOMAIN=dev-jw5wgp2b.us.auth0.com
# AUTH0_AUDIENCE=https://prod.stewardacs.xyz/mcp/sse
# AUTH0_AUDIENCE_URLENC=https%3A%2F%2Fprod.stewardacs.xyz%2Fmcp%2Fsse
# AUTH0_ISSUER=
# MCP_PUBLIC_URL=https://prod.stewardacs.xyz
# MCP_RESOURCE_URL=https://prod.stewardacs.xyz/mcp/sse
# AUTH0_MGMT_CLIENT_ID=
# AUTH0_MGMT_CLIENT_SECRET=
# AUTH0_CONNECTION=email

# ─── Postgres override (docker-compose.postgres.yml) ─────────────────────────
# DB_USER=postgres
# DB_PASSWORD=
# DB_NAME=acs_prod

# ─── Memory ─────────────────────────────────────────────────────────────────
# MEMORY_STORE=obsidian
# OBSIDIAN_VAULT_PATH=/vaults

# ─── Production observability (Axiom, optional) ──────────────────────────────
# Create the dataset once in Axiom, then provide an ingest-scoped token.
AXIOM_LOGS=
AXIOM_DATASET=steward-acs
# AXIOM_DOMAIN=https://api.axiom.co

# ─── Per-org Syncthing API keys ──────────────────────────────────────────────
# Admin UI: SSH tunnel to container :8384 only (not published via Caddy).
# SYNCTHING_DEFAULT_API_KEY=
# SYNCTHING_PROD_API_KEY=
# SYNCTHING_FSGBHUTAN_API_KEY=
# SYNCTHING_SAFETYCONNECT_API_KEY=

# ─── LLM providers (optional) ────────────────────────────────────────────────
# ENABLED_LLM_PROVIDERS=
# MIMO_API_KEY=
# NIM_API_KEY=
# MINIMAX_API_KEY=
# OPENAI_API_KEY=
