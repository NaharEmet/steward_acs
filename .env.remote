# Remote production deployment
# Copy to .env and fill in values before:
#   docker compose -f docker-compose.remote.yml up -d --build

# ─── Required ───────────────────────────────────────────────────────────────
DOMAIN=steward.example.com
PHX_HOST=steward.example.com
SECRET_KEY_BASE=
MCP_API_KEY=
SERVICE_API_KEY=
DB_PASSWORD=
ACS_USERNAME=admin
ACS_PASSWORD=

# Optional: bake a stable cookie signing salt into the release image at build time.
# If unset, runtime SECRET_KEY_BASE-derived salt is used instead.
# COOKIE_SIGNING_SALT=

# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_NAME=acs_prod

# ─── Dashboard / org ─────────────────────────────────────────────────────────
ACS_ORG_NAME=default
ACS_DEVELOPER_NAME=unknown

# ─── MCP / logging ───────────────────────────────────────────────────────────
LOG_INGEST_KEY=
MCP_QUERY_KEY_AUTH=true

# ─── MCP OAuth (Auth0) — Claude web Connectors ───────────────────────────────
# Enable JWT validation for Claude Custom Connectors (Auth0 OAuth flow).
# API keys (MCP_API_KEY / acs_dev_...) still work for Claude Code and plugins.
OAUTH_BEARER_ENABLED=true
AUTH0_DOMAIN=dev-jw5wgp2b.us.auth0.com
AUTH0_AUDIENCE=https://prod.stewardacs.xyz/mcp/sse
MCP_PUBLIC_URL=https://prod.stewardacs.xyz
MCP_RESOURCE_URL=https://prod.stewardacs.xyz/mcp/sse
# Optional override (defaults to https://${AUTH0_DOMAIN}/)
# AUTH0_ISSUER=https://dev-jw5wgp2b.us.auth0.com/

# Auth0 connection name for user provisioning — set to a passwordless
# connection (e.g. "email") for magic-link auth, or "Username-Password-Authentication"
# for traditional password-based auth. Defaults to "email" (magic links).
# AUTH0_CONNECTION=email

# ─── Auth0 Management API (for admin user provisioning) ───────────────────────
# Credentials for a Machine-to-Machine Application in Auth0 with scope
# `create:users` on the Management API. Used by the `create_user` MCP tool.
# See certs/Oauth.md for the reference credentials.
AUTH0_MGMT_CLIENT_ID=74wSfLA2TYUxfJ0kpa2XaSG9KZ0NnzCk
AUTH0_MGMT_CLIENT_SECRET=5Y07h4mefmWW3_ds_OgesRXcqgj0XAeNinXvZOP6hgITY8VzEvHyRYFDSxXyFFnC

# ─── Memory ───────────────────────────────────────────────────────────────────
MEMORY_STORE=obsidian
OBSIDIAN_VAULT_PATH=/obsidian
# Path to the LLM evaluation prompt file (shipped in the Docker image).
# Override with a path in your Obsidian vault to make it editable via sync.
# MEMORY_EVALUATION_PROMPT_PATH=/app/priv/evaluation_prompt/evaluate.txt

# ─── Syncthing (Obsidian vault sync) ───────────────────────────────────────────
STGUIAPIKEY=
SYNC_BCRYPT_PASS=
SYNC_USERNAME=syncuser
OBSIDIAN_DOMAIN=obsidian.steward.xyz

# ─── LLM providers (optional) ─────────────────────────────────────────────────
ENABLED_LLM_PROVIDERS=
MIMO_API_KEY=
NIM_API_KEY=
MINIMAX_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=
OLLAMA_URL=

# ─── Meta-harness (analysis & reporting) ─────────────────────────────────────
META_HARNESS_ENABLED=true

# ─── Security / network (optional) ───────────────────────────────────────────
# Comma-separated allowed browser origins for CORS (defaults to wildcard in config.exs)
# CORS_ORIGINS=https://steward.example.com
# BRIDGE_ALLOWED_HOSTS=internal-service,api.example.com
