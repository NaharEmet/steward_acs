# Local development environment for Steward ACS
# Copy to .env and edit before running: cp .env.example .env
# docker compose up -d

# ─── LLM Providers (at least one needed for memory auditing) ─────────────────
# Without these, memories won't be auto-audited (Audit failed: :no_providers_enabled)
# NIM_API_KEY=
# MIMO_API_KEY=
# MINIMAX_API_KEY=
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# ─── Memory Auditor Evaluation Prompt ────────────────────────────────────────
# Load the LLM evaluation prompt from a file (supports {{memory_json}} and
# {{existing_memories_json}} template variables). Falls back to hardcoded default.
# MEMORY_EVALUATION_PROMPT_PATH=/etc/steward/prompts/evaluate.md

# ─── Memory Auditor Pre-filter Rules ─────────────────────────────────────────
# Comma-separated patterns for auto-rejection of proposed memories.
# AUDITOR_INTERVAL=30000
# AUDITOR_MAX_CONCURRENCY=20
# AUDITOR_REJECT_TITLE_PREFIXES=Key learning from task,Issue encountered in task
# AUDITOR_REJECT_TITLE_EXACT=Improvement suggestion from task feedback
# AUDITOR_REJECT_SCOPE_PREFIXES=test/,test_app/
# AUDITOR_REJECT_ID_PREFIXES=lifecycle_rebuild
# AUDITOR_REJECT_ID_CONTAINS=guidance_test,e2e_pipeline,test_hybrid
# AUDITOR_MIN_CONTENT_LENGTH=20
# AUDITOR_LOW_CONTENT_LENGTH=50
# AUDITOR_FUZZY_THRESHOLD=0.85
# AUDITOR_REJECT_EMPTY_SCOPE=true
# AUDITOR_REJECT_TITLE_EQUALS_CONTENT=true

# ─── MCP Tools Path ──────────────────────────────────────────────────────────
# Point to your YAML tool definitions directory (comma-separated for multiple dirs)
# Default: /app/acs/acstools (inside container)
# MCP_TOOLS_PATH=./acstools

# ─── Dashboard OAuth (Auth0 Regular Web Application) ────────────────────────
# OIDC_BROWSER_ENABLED=false
# AUTH0_WEB_CLIENT_ID=
# AUTH0_WEB_CLIENT_SECRET=
# AUTH0_WEB_REDIRECT_URI=http://localhost:4001/auth/callback
# ACCOUNT_HOST=localhost
# Allow verified, orgless OAuth users to create an organization.
# SELF_SERVICE_ORGS_ENABLED=false

# ─── Multi-tenant ────────────────────────────────────────────────────────────
# Set MULTI_TENANT=true via docker-compose.multitenant.yml. Requires BASE_DOMAIN.
# See .env.multitenant and guides/deployment.md / priv/skills/deployment.md.
# MULTI_TENANT=false
# BASE_DOMAIN=stewardacs.xyz
# ACS_ORG_NAME=default
# ORGS_FILE=/path/to/orgs.json

# ─── MCP Auth ────────────────────────────────────────────────────────────────
# MCP_API_KEY=
# SERVICE_API_KEY=
# MCP_QUERY_KEY_AUTH=false

# ─── MCP OAuth (Auth0) — optional, for Claude Connectors on prod ─────────────
# OAUTH_BEARER_ENABLED=false
# AUTH0_DOMAIN=dev-jw5wgp2b.us.auth0.com
# AUTH0_AUDIENCE=https://prod.stewardacs.xyz/mcp/sse
# MCP_PUBLIC_URL=https://prod.stewardacs.xyz
# MCP_RESOURCE_URL=https://prod.stewardacs.xyz/mcp/sse

# ─── Production observability (Axiom) ────────────────────────────────────────
# Traces and logs ship only from MIX_ENV=prod and only when AXIOM_LOGS is set.
# Local development never exports, even if these values exist in .env.
# AXIOM_LOGS=
# AXIOM_DATASET=steward-acs
# AXIOM_DOMAIN=https://api.axiom.co

# ─── Meta-Harness (analysis & reporting) ─────────────────────────────────────
# Enable only on servers that generate analysis reports.
# META_HARNESS_ENABLED=true

# ─── Org ───────────────────────────────────────────────────────────────────────
# ACS_ORG_NAME=default
# ACS_DEVELOPER_NAME=unknown
# ACS_PROJECT_NAME=
