# ─── Steward ACS — Environment Template ─────────────────────────────────────
# Copy to .env and fill in your values. Generate SECRET_KEY_BASE with: mix phx.gen.secret

# Core
SECRET_KEY_BASE=
MCP_API_KEY=acs_dev_key
SERVICE_API_KEY=acs_svc_key
LOG_INGEST_KEY=acs_log_key

# LLM Provider (pick one)
# Option A: NVIDIA NIM
# NIM_API_KEY=
# ENABLED_LLM_PROVIDERS=nim

# Option B: MiniMax
# MINIMAX_API_KEY=
# ENABLED_LLM_PROVIDERS=minimax

# Option C: MIMO
# MIMO_API_KEY=
# ENABLED_LLM_PROVIDERS=mimo

# Option D: OpenAI-compatible (any OpenAI API endpoint — including local)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
# ENABLED_LLM_PROVIDERS=openai

# Database (SQLite by default, set DATABASE_URL for PostgreSQL)
DATABASE_PATH=../../var/acs.sqlite
# DATABASE_URL=ecto://user:pass@host:5432/acs_prod

# Embeddings
# OLLAMA_URL=http://localhost:11434

# Auditor
AUDITOR_INTERVAL=30000

# Optional
# ACS_CLUSTER_NAME=default
# ACS_DEVELOPER_NAME=unknown
# ADMIN_EMAILS=
# ALLOWED_PATHS=/tmp,/app
# ALLOWED_COMMANDS=echo,ls,cat
# HTTP_SLEEP_MAX_MS=300000