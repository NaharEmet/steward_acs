# ACS Environment Configuration Template
config :steward_acs, :nvidia_nim_api_key, ""
config :steward_acs, :minimax_api_key, ""
config :steward_acs, :mimo_api_key, ""
DATABASE_PATH=../../var/acs.sqlite
AUDITOR_INTERVAL=30000
OLLAMA_URL=http://localhost:11434

# Whitelist of enabled LLM providers (comma-separated)
# If empty, all providers with configured API keys are tried.
# Set to limit which providers are used:
# ENABLED_LLM_PROVIDERS=mimo               # MIMO only
# ENABLED_LLM_PROVIDERS=mimo,minimax       # MIMO + MiniMax
# ENABLED_LLM_PROVIDERS=                   # all configured providers