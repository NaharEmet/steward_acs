<!DOCTYPE html>
<html lang="en" class="h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Steward</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500;600&family=Syne:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      /* ═══════════════════════════════════════════════════════════════
         DESIGN SYSTEM TOKENS
         ═══════════════════════════════════════════════════════════════ */
      :root {
        --bg: #0f0f12;
        --bg-card: #18181f;
        --bg-elevated: #1e1e28;
        --bg-input: #141418;

        --text: #ecece6;
        --text-dim: #9a9a8e;
        --muted: #6b6b60;

        --accent: #D4785C;
        --accent-glow: rgba(212, 120, 92, 0.15);
        --accent-subtle: rgba(212, 120, 92, 0.08);

        --green: #8EA67A;
        --green-glow: rgba(142, 166, 122, 0.15);
        --red: #C96A6A;
        --red-glow: rgba(201, 106, 106, 0.15);
        --amber: #C9A86A;
        --amber-glow: rgba(201, 168, 106, 0.15);
        --teal: #5A8A8A;
        --teal-glow: rgba(90, 138, 138, 0.15);

        --border: #262624;
        --border-light: #333330;
        --border-accent: rgba(212, 120, 92, 0.4);

        --radius-sm: 4px;
        --radius: 8px;
        --radius-lg: 12px;

        --font-display: 'Syne', sans-serif;
        --font-body: 'DM Sans', sans-serif;
        --font-mono: 'JetBrains Mono', monospace;

        --transition-fast: 180ms cubic-bezier(0.22, 1, 0.36, 1);
        --transition: 350ms cubic-bezier(0.22, 1, 0.36, 1);
        --transition-slow: 600ms cubic-bezier(0.22, 1, 0.36, 1);
      }

      /* ═══════════════════════════════════════════════════════════════
         RESET & BASE
         ═══════════════════════════════════════════════════════════════ */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      html { font-size: 16px; }

      body {
        font-family: var(--font-body);
        background-color: var(--bg);
        background-image:
          radial-gradient(ellipse 90% 60% at 5% 10%, rgba(212, 120, 92, 0.10), transparent),
          radial-gradient(ellipse 70% 50% at 95% 85%, rgba(90, 138, 138, 0.08), transparent),
          radial-gradient(ellipse 60% 40% at 50% 40%, rgba(201, 168, 106, 0.03), transparent);
        color: var(--text);
        min-height: 100vh;
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      /* ── Noise texture overlay ── */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
        background-repeat: repeat;
        background-size: 256px 256px;
        pointer-events: none;
        z-index: 9999;
      }

      /* ── Scanline overlay (subtle) ── */
      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.025) 2px,
          rgba(0, 0, 0, 0.025) 4px
        );
        pointer-events: none;
        z-index: 9998;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-display);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.15;
      }

      code, pre, .mono { font-family: var(--font-mono); }

      a { color: inherit; text-decoration: none; }

      /* ── Selection ── */
      ::selection { background: var(--accent); color: #fff; }

      /* ═══════════════════════════════════════════════════════════════
         SCROLLBAR
         ═══════════════════════════════════════════════════════════════ */
      ::-webkit-scrollbar { width: 5px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb {
        background: var(--border-light);
        border-radius: 3px;
      }
      ::-webkit-scrollbar-thumb:hover { background: var(--muted); }

      /* ═══════════════════════════════════════════════════════════════
         UTILITY CLASSES
         ═══════════════════════════════════════════════════════════════ */
      .text-accent { color: var(--accent); }
      .text-dim { color: var(--text-dim); }
      .text-muted { color: var(--muted); }
      .text-green { color: var(--green); }
      .text-red { color: var(--red); }
      .text-amber { color: var(--amber); }
      .text-teal { color: var(--teal); }

      /* ═══════════════════════════════════════════════════════════════
         HEADER — dramatic glass with geometric accent
         ═══════════════════════════════════════════════════════════════ */
      .header {
        border-bottom: 1px solid var(--border);
        background: rgba(15, 15, 18, 0.85);
        backdrop-filter: blur(16px) saturate(1.2);
        position: sticky;
        top: 0;
        z-index: 100;
      }

      /* Glow line beneath header */
      .header::after {
        content: '';
        position: absolute;
        bottom: -1px;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg,
          transparent 0%,
          var(--accent) 20%,
          var(--teal) 50%,
          var(--accent) 80%,
          transparent 100%
        );
        opacity: 0.3;
      }

      .header-inner {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 24px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .logo {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0;
        position: relative;
        line-height: 1;
      }

      .logo-mark {
        font-family: var(--font-display);
        font-size: 1.5rem;
        font-weight: 800;
        background: linear-gradient(135deg, var(--accent), var(--teal));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        letter-spacing: -0.03em;
      }

      .logo-text {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .header-meta {
        display: flex;
        align-items: center;
        gap: 12px;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 8px;
      }

      .port-badge {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--muted);
        padding: 4px 10px;
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        letter-spacing: 0.04em;
      }

      .project-sub {
        font-family: var(--font-mono);
        font-size: 0.55rem;
        color: var(--muted);
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-top: 1px;
      }

      /* ═══════════════════════════════════════════════════════════════
         MAIN
         ═══════════════════════════════════════════════════════════════ */
      .main {
        max-width: 1400px;
        margin: 0 auto;
        padding: 32px 24px 80px;
      }

      /* ═══════════════════════════════════════════════════════════════
         CARD SYSTEM — with inner glow and depth
         ═══════════════════════════════════════════════════════════════ */
      .card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        position: relative;
        overflow: hidden;
        transition: border-color var(--transition), box-shadow var(--transition);
      }

      .card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.06), transparent);
      }

      /* Inner glow on hover */
      .card::after {
        content: '';
        position: absolute;
        inset: 0;
        border-radius: inherit;
        background: radial-gradient(ellipse 100% 80% at 50% 0%, var(--accent-glow), transparent);
        opacity: 0;
        transition: opacity var(--transition);
        pointer-events: none;
      }

      .card:hover {
        border-color: var(--border-light);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }

      .card:hover::after { opacity: 1; }

      .card-elevated {
        background: var(--bg-elevated);
        border: 1px solid var(--border-light);
        border-radius: var(--radius);
      }

      /* ═══════════════════════════════════════════════════════════════
         BUTTONS — with shine sweep on hover
         ═══════════════════════════════════════════════════════════════ */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        padding: 10px 20px;
        font-family: var(--font-mono);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border-radius: var(--radius);
        border: 1px solid transparent;
        cursor: pointer;
        transition: all var(--transition-fast);
        position: relative;
        overflow: hidden;
        outline: none;
      }

      .btn::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0;
        transition: opacity var(--transition-fast);
      }

      .btn:hover::before { opacity: 1; }
      .btn:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
      .btn:active { transform: scale(0.97); }

      /* Shine sweep */
      .btn::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 60%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.08), transparent);
        transform: skewX(-15deg);
        transition: none;
      }

      .btn:hover::after {
        left: 150%;
        transition: left 0.6s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .btn-primary {
        background: var(--accent);
        color: #fff;
        border-color: var(--accent);
      }
      .btn-primary::before {
        background: linear-gradient(135deg, rgba(255,255,255,0.12), transparent);
      }
      .btn-primary:hover {
        box-shadow: 0 0 24px var(--accent-glow), 0 4px 16px rgba(0,0,0,0.3);
      }

      .btn-ghost {
        background: transparent;
        color: var(--text-dim);
        border-color: var(--border-light);
      }
      .btn-ghost::before { background: var(--bg-elevated); }
      .btn-ghost:hover {
        color: var(--text);
        border-color: var(--border-accent);
      }

      .btn-danger {
        background: transparent;
        color: var(--red);
        border-color: rgba(201, 106, 106, 0.25);
      }
      .btn-danger::before { background: var(--red-glow); }
      .btn-danger:hover {
        border-color: var(--red);
        box-shadow: 0 0 18px var(--red-glow);
      }

      /* ═══════════════════════════════════════════════════════════════
         STATUS INDICATORS — pulse ring
         ═══════════════════════════════════════════════════════════════ */
      .status-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        position: relative;
        flex-shrink: 0;
      }

      .status-dot::after {
        content: '';
        position: absolute;
        inset: -3px;
        border-radius: 50%;
        border: 1.5px solid transparent;
        opacity: 0.4;
      }

      .status-dot.working {
        background: var(--green);
        box-shadow: 0 0 10px var(--green-glow);
      }
      .status-dot.working::after {
        border-color: var(--green);
        animation: pulse-ring 2s ease-in-out infinite;
      }

      .status-dot.sleeping {
        background: var(--amber);
      }
      .status-dot.sleeping::after {
        border-color: var(--amber);
        animation: pulse-ring-amber 3s ease-in-out infinite;
      }

      @keyframes pulse-ring {
        0%, 100% { transform: scale(1); opacity: 0.4; }
        50% { transform: scale(1.5); opacity: 0; }
      }

      @keyframes pulse-ring-amber {
        0%, 100% { transform: scale(1); opacity: 0.3; }
        50% { transform: scale(1.6); opacity: 0; }
      }

      /* ═══════════════════════════════════════════════════════════════
         STATUS BADGES
         ═══════════════════════════════════════════════════════════════ */
      .badge {
        display: inline-flex;
        align-items: center;
        padding: 4px 12px;
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border-radius: 20px;
      }

      .badge-working {
        background: var(--green-glow);
        color: var(--green);
        border: 1px solid rgba(142, 166, 122, 0.2);
      }

      .badge-sleeping {
        background: var(--amber-glow);
        color: var(--amber);
        border: 1px solid rgba(201, 168, 106, 0.2);
      }

      .badge-status {
        padding: 3px 10px;
        border-radius: var(--radius-sm);
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .badge-todo { background: var(--bg-elevated); color: var(--text-dim); }
      .badge-in_progress { background: var(--teal-glow); color: var(--teal); border: 1px solid rgba(90,138,138,0.15); }
      .badge-done { background: var(--green-glow); color: var(--green); border: 1px solid rgba(142,166,122,0.15); }
      .badge-blocked { background: var(--red-glow); color: var(--red); border: 1px solid rgba(201,106,106,0.15); }
      .badge-in_review { background: var(--accent-subtle); color: var(--accent); border: 1px solid var(--border-accent); }
      .badge-new { background: var(--red-glow); color: var(--red); border: 1px solid rgba(201,106,106,0.15); }
      .badge-acknowledged { background: var(--amber-glow); color: var(--amber); border: 1px solid rgba(201,168,106,0.15); }
      .badge-tasked { background: var(--teal-glow); color: var(--teal); border: 1px solid rgba(90,138,138,0.15); }
      .badge-resolved { background: var(--green-glow); color: var(--green); border: 1px solid rgba(142,166,122,0.15); }
      .badge-failed { background: var(--bg-elevated); color: var(--muted); border: 1px solid var(--border); }

      /* ═══════════════════════════════════════════════════════════════
         FILTER TABS — pill buttons
         ═══════════════════════════════════════════════════════════════ */
      .filter-tabs {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
      }

      .filter-tab {
        padding: 7px 14px;
        font-family: var(--font-mono);
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        color: var(--muted);
        background: transparent;
        border: 1px solid transparent;
        border-radius: var(--radius);
        cursor: pointer;
        transition: all var(--transition-fast);
      }

      .filter-tab:hover {
        color: var(--text-dim);
        background: var(--bg-elevated);
        border-color: var(--border);
      }

      .filter-tab.active {
        color: var(--accent);
        background: var(--accent-subtle);
        border-color: var(--border-accent);
        box-shadow: 0 0 12px var(--accent-glow);
      }

      /* ═══════════════════════════════════════════════════════════════
         TASK ITEMS — leading accent line, hover lift
         ═══════════════════════════════════════════════════════════════ */
      .task-item {
        position: relative;
        padding: 14px 16px;
        background: var(--bg);
        border-radius: var(--radius);
        border-left: 3px solid var(--teal);
        transition: all var(--transition-fast);
      }

      .task-item:hover {
        background: var(--bg-input);
        transform: translateX(4px);
        box-shadow: 0 2px 12px rgba(0,0,0,0.2);
      }

      .task-item.priority {
        border-left-color: var(--amber);
      }

      .task-item.priority::before {
        content: '⚠';
        position: absolute;
        right: 14px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 0.7rem;
        opacity: 0.3;
        font-family: var(--font-body);
      }

      .task-item.priority:hover {
        border-left-color: var(--amber);
        box-shadow: 0 2px 12px var(--amber-glow);
      }

      /* ═══════════════════════════════════════════════════════════════
         LOCK ITEMS — red accent, hover lift
         ═══════════════════════════════════════════════════════════════ */
      .lock-item {
        position: relative;
        padding: 12px 14px;
        background: var(--bg);
        border-radius: var(--radius);
        border-left: 3px solid var(--red);
        transition: all var(--transition-fast);
      }

      .lock-item:hover {
        background: var(--bg-input);
        transform: translateX(4px);
        box-shadow: 0 2px 12px rgba(0,0,0,0.2);
      }

      .lock-item:hover code {
        color: var(--text-dim);
      }

      /* ═══════════════════════════════════════════════════════════════
         SECTION HEADERS
         ═══════════════════════════════════════════════════════════════ */
      .section-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
      }

      .section-title {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text);
        letter-spacing: -0.02em;
      }

      .section-count {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        color: var(--muted);
        padding: 2px 8px;
        background: var(--bg-elevated);
        border-radius: var(--radius-sm);
        letter-spacing: 0.03em;
      }

      /* ═══════════════════════════════════════════════════════════════
         FLASH MESSAGES — slide-in with glow
         ═══════════════════════════════════════════════════════════════ */
      .flash {
        padding: 14px 18px;
        border-radius: var(--radius);
        font-size: 0.85rem;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
        animation: flashIn 400ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .flash-info {
        background: var(--accent-subtle);
        border: 1px solid var(--border-accent);
        color: var(--accent);
        box-shadow: 0 0 20px var(--accent-glow);
      }

      .flash-error {
        background: var(--red-glow);
        border: 1px solid rgba(201, 106, 106, 0.3);
        color: var(--red);
        box-shadow: 0 0 20px var(--red-glow);
      }

      @keyframes flashIn {
        from { opacity: 0; transform: translateY(-12px) scale(0.98); }
        to { opacity: 1; transform: translateY(0) scale(1); }
      }

      @keyframes animate-in {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
      }

      .animate-in {
        animation: animate-in 400ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
        opacity: 0;
      }
      .animate-in.delay-1 { animation-delay: 100ms; }
      .animate-in.delay-2 { animation-delay: 200ms; }

      /* ═══════════════════════════════════════════════════════════════
         GRID LAYOUTS
         ═══════════════════════════════════════════════════════════════ */
      .agents-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 16px;
      }

      .two-col-grid {
        display: grid;
        grid-template-columns: 1.2fr 0.8fr;
        gap: 20px;
      }

      @media (max-width: 900px) {
        .two-col-grid { grid-template-columns: 1fr; }
      }

      /* ═══════════════════════════════════════════════════════════════
         AGENT CARD — hover glow lift
         ═══════════════════════════════════════════════════════════════ */
      .agent-card {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 20px;
        transition: all var(--transition);
        position: relative;
        overflow: hidden;
      }

      .agent-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.04), transparent);
      }

      /* Inner accent glow on hover */
      .agent-card::after {
        content: '';
        position: absolute;
        top: -50%;
        left: -50%;
        width: 200%;
        height: 200%;
        background: radial-gradient(ellipse at 30% 0%, var(--accent-glow), transparent 60%);
        opacity: 0;
        transition: opacity var(--transition);
        pointer-events: none;
      }

      .agent-card:hover {
        border-color: var(--border-light);
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(0,0,0,0.3);
      }

      .agent-card:hover::after {
        opacity: 1;
      }

      .agent-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        position: relative;
        z-index: 1;
      }

      .agent-name {
        font-family: var(--font-display);
        font-size: 1.05rem;
        font-weight: 700;
        color: var(--text);
        flex: 1;
      }

      .agent-task-box {
        background: var(--bg);
        border-radius: var(--radius);
        padding: 14px;
        margin-bottom: 12px;
        position: relative;
        z-index: 1;
      }

      .agent-task-label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
        margin-bottom: 6px;
      }

      .agent-task-title {
        font-size: 0.88rem;
        font-weight: 500;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .agent-task-desc {
        font-size: 0.78rem;
        color: var(--text-dim);
        margin-top: 4px;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }

      .agent-locks {
        margin-top: 12px;
        padding-top: 12px;
        border-top: 1px solid var(--border);
        position: relative;
        z-index: 1;
      }

      .agent-locks-label {
        font-family: var(--font-mono);
        font-size: 0.6rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--muted);
        margin-bottom: 8px;
      }

      .lock-file-tag {
        display: inline-block;
        font-family: var(--font-mono);
        font-size: 0.68rem;
        padding: 3px 8px;
        background: var(--red-glow);
        color: var(--red);
        border-radius: var(--radius-sm);
        margin-right: 6px;
        margin-bottom: 6px;
        max-width: 180px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        border: 1px solid rgba(201,106,106,0.1);
        transition: all var(--transition-fast);
      }

      .lock-file-tag:hover {
        background: rgba(201,106,106,0.25);
        max-width: none;
      }

      /* ═══════════════════════════════════════════════════════════════
         EMPTY STATES
         ═══════════════════════════════════════════════════════════════ */
      .empty-state {
        text-align: center;
        padding: 48px 24px;
        color: var(--muted);
      }

      .empty-state-icon {
        font-size: 2rem;
        margin-bottom: 12px;
        opacity: 0.3;
        font-family: var(--font-body);
      }

      .empty-state-title {
        font-size: 1rem;
        font-weight: 500;
        color: var(--text-dim);
        margin-bottom: 4px;
      }

      .empty-state-desc {
        font-size: 0.82rem;
        color: var(--muted);
      }

      /* ═══════════════════════════════════════════════════════════════
         SCROLLABLE AREAS
         ═══════════════════════════════════════════════════════════════ */
      .scroll-area {
        max-height: 480px;
        overflow-y: auto;
        padding-right: 8px;
      }

      /* ═══════════════════════════════════════════════════════════════
         TIMESTAMPS
         ═══════════════════════════════════════════════════════════════ */
      .timestamp {
        font-family: var(--font-mono);
        font-size: 0.7rem;
        color: var(--muted);
        letter-spacing: -0.01em;
      }

      /* ═══════════════════════════════════════════════════════════════
         GEOMETRIC ACCENT — decorative corner marker on the dashboard
         ═══════════════════════════════════════════════════════════════ */
      .dashboard-frame {
        position: relative;
      }

      .dashboard-frame::before,
      .dashboard-frame::after {
        content: '';
        position: absolute;
        width: 24px;
        height: 24px;
        opacity: 0.15;
        pointer-events: none;
      }

      .dashboard-frame::before {
        top: -8px;
        left: -8px;
        border-top: 1px solid var(--accent);
        border-left: 1px solid var(--accent);
      }

      .dashboard-frame::after {
        bottom: -8px;
        right: -8px;
        border-bottom: 1px solid var(--teal);
        border-right: 1px solid var(--teal);
      }

      /* ═══════════════════════════════════════════════════════════════
         NAVIGATION TABS
         ═══════════════════════════════════════════════════════════════ */
      .nav-tab {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        font-family: var(--font-mono);
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.03em;
        color: var(--muted);
        border-radius: var(--radius);
        transition: all var(--transition-fast);
        text-decoration: none;
      }
      .nav-tab:hover {
        color: var(--text-dim);
        background: var(--bg-elevated);
      }
      .nav-tab.active {
        color: var(--accent);
        background: var(--accent-subtle);
        transition: all var(--transition-fast);
      }
      .pending-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 18px;
        height: 18px;
        padding: 0 5px;
        background: var(--accent);
        color: #fff;
        border-radius: 10px;
        font-size: 0.6rem;
        font-weight: 700;
        font-family: var(--font-mono);
      }

      /* ═══════════════════════════════════════════════════════════════
         TOOLS DASHBOARD
         ═══════════════════════════════════════════════════════════════ */
      .health-dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
      }
      .health-dot.up {
        background: var(--green);
        box-shadow: 0 0 8px var(--green-glow);
      }
      .health-dot.down {
        background: var(--red);
        box-shadow: 0 0 8px var(--red-glow);
      }
      .health-dot.unknown {
        background: var(--muted);
      }

      /* ═══════════════════════════════════════════════════════════════
         MEMORY STATUS DOTS — color per status
         ═══════════════════════════════════════════════════════════════ */
      .status-dot.proposed {
        background: var(--amber);
        box-shadow: 0 0 8px var(--amber-glow);
      }
      .status-dot.proposed::after {
        border-color: var(--amber);
        animation: pulse-ring-amber 2.5s ease-in-out infinite;
      }

      .status-dot.approved {
        background: var(--green);
        box-shadow: 0 0 8px var(--green-glow);
      }
      .status-dot.approved::after {
        border-color: var(--green);
        animation: pulse-ring 3s ease-in-out infinite;
      }

      .status-dot.rejected {
        background: var(--red);
        box-shadow: 0 0 8px var(--red-glow);
      }
      .status-dot.rejected::after {
        border-color: var(--red);
        opacity: 0.3;
      }

      .status-dot.stale {
        background: var(--muted);
      }
      .status-dot.stale::after {
        border-color: var(--muted);
        opacity: 0.2;
      }

      .status-dot.deprecated {
        background: var(--muted);
      }
      .status-dot.deprecated::after {
        border-color: var(--muted);
        opacity: 0.2;
      }

      .status-dot.archived {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
      }
      .status-dot.archived::after {
        display: none;
      }

      .status-dot.parse_error {
        background: var(--red);
        box-shadow: 0 0 8px var(--red-glow);
        animation: pulse-ring 1.5s ease-in-out infinite;
      }

      .tool-row {
        padding: 12px 16px;
        background: var(--bg);
        border-radius: var(--radius);
        border: 1px solid transparent;
        transition: all var(--transition-fast);
        cursor: pointer;
      }
      .tool-row:hover {
        border-color: var(--border-light);
        box-shadow: 0 2px 12px rgba(0,0,0,0.15);
      }
      .tool-row.selected {
        border-color: var(--border-accent);
        box-shadow: 0 0 16px var(--accent-glow);
      }

      .tool-detail {
        animation: riseIn 300ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .category-badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        border-radius: 20px;
        background: var(--teal-glow);
        color: var(--teal);
        border: 1px solid rgba(90, 138, 138, 0.2);
      }

      .level-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 22px;
        height: 22px;
        padding: 0 6px;
        font-family: var(--font-mono);
        font-size: 0.6rem;
        font-weight: 600;
        border-radius: var(--radius-sm);
        background: var(--bg-elevated);
        color: var(--muted);
        border: 1px solid var(--border);
      }

      /* ═══════════════════════════════════════════════════════════════
         TOOL REQUESTS
         ═══════════════════════════════════════════════════════════════ */
      .request-card {
        padding: 20px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        transition: border-color var(--transition-fast);
      }
      .request-card:hover {
        border-color: var(--border-light);
      }

      .request-actions {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--border);
      }

      .badge-pending {
        background: var(--amber-glow);
        color: var(--amber);
        border: 1px solid rgba(201, 168, 106, 0.2);
      }
      .badge-approved {
        background: var(--green-glow);
        color: var(--green);
        border: 1px solid rgba(142, 166, 122, 0.2);
      }
      .badge-rejected {
        background: var(--red-glow);
        color: var(--red);
        border: 1px solid rgba(201, 106, 106, 0.2);
      }

      .requests-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.82rem;
      }
      .requests-table th {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        padding: 10px 14px;
        text-align: left;
        border-bottom: 1px solid var(--border);
      }
      .requests-table td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--border);
        color: var(--text-dim);
      }
      .requests-table tr:hover td {
        background: rgba(255,255,255,0.02);
      }

      .stat-card-value {
        font-family: var(--font-display);
        font-size: 2rem;
        font-weight: 700;
        color: var(--text);
      }
      .stat-card-label {
        font-family: var(--font-mono);
        font-size: 0.65rem;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 8px;
      }

      /* ═══════════════════════════════════════════════════════════════
         ACCOUNT DESK & ACCESS CONTROL
         A restrained operations-dossier layer for identity workflows.
         ═══════════════════════════════════════════════════════════════ */
      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }

      .header-inner {
        min-height: 64px;
        height: auto;
        gap: 20px;
      }

      .header-primary,
      .primary-nav,
      .brand-link,
      .organization-pill,
      .user-identity {
        display: flex;
        align-items: center;
      }

      .header-primary {
        min-width: 0;
        flex: 1;
        gap: clamp(18px, 2.4vw, 34px);
      }

      .brand-link {
        flex: 0 0 auto;
        transition: opacity var(--transition-fast);
      }

      .brand-link:hover { opacity: 0.82; }
      .brand-link:focus-visible { outline: 2px solid var(--accent); outline-offset: 6px; }

      .primary-nav {
        min-width: 0;
        gap: 2px;
        overflow-x: auto;
        scrollbar-width: none;
      }

      .primary-nav::-webkit-scrollbar { display: none; }
      .primary-nav .nav-tab { flex: 0 0 auto; padding: 8px 11px; }
      .account-nav { overflow: visible; }

      .nav-workspace {
        color: var(--green);
        border: 1px solid rgba(142, 166, 122, 0.2);
      }

      .nav-workspace:hover {
        color: var(--green);
        border-color: rgba(142, 166, 122, 0.45);
        background: var(--green-glow);
      }

      .organization-pill {
        max-width: 170px;
        gap: 7px;
        padding: 5px 9px;
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        background: var(--bg-elevated);
        color: var(--text-dim);
        font-family: var(--font-mono);
        font-size: 0.66rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .organization-signal {
        width: 6px;
        height: 6px;
        flex: 0 0 auto;
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 8px var(--green);
      }

      .header-button { padding: 7px 11px; font-size: 0.68rem; }

      .user-identity {
        max-width: 200px;
        align-items: flex-end;
        flex-direction: column;
        line-height: 1.15;
      }

      .user-identity > span:first-child {
        max-width: 100%;
        color: var(--text-dim);
        font-size: 0.7rem;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }

      .user-role {
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.56rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .user-role.role-owner { color: var(--accent); }
      .user-role.role-admin { color: var(--teal); }

      .account-shell {
        width: min(100%, 1180px);
        margin: 0 auto;
        position: relative;
      }

      .account-shell-narrow { width: min(100%, 880px); }

      .account-intro {
        max-width: 780px;
        margin-bottom: 30px;
        position: relative;
      }

      .account-intro::before {
        content: '';
        position: absolute;
        top: 3px;
        left: -24px;
        width: 1px;
        height: 100%;
        background: linear-gradient(var(--accent), transparent);
        opacity: 0.65;
      }

      .account-intro h1 {
        max-width: 760px;
        margin: 9px 0 12px;
        color: var(--text);
        font-size: clamp(2.15rem, 5vw, 4.35rem);
        font-weight: 700;
        letter-spacing: -0.055em;
        line-height: 0.98;
      }

      .account-intro > p:last-child {
        max-width: 680px;
        color: var(--text-dim);
        font-size: clamp(0.94rem, 1.6vw, 1.08rem);
        line-height: 1.65;
      }

      .account-kicker {
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.66rem;
        font-weight: 600;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .account-kicker span { color: var(--accent); }

      .signal-rail {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        margin: 0 0 18px;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: rgba(20, 20, 24, 0.72);
        overflow: hidden;
      }

      .signal-step {
        min-height: 48px;
        display: flex;
        align-items: center;
        gap: 9px;
        padding: 10px 14px;
        border-right: 1px solid var(--border);
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.65rem;
        letter-spacing: 0.03em;
      }

      .signal-step:last-child { border-right: 0; }

      .signal-step span {
        color: var(--muted);
        font-size: 0.56rem;
        letter-spacing: 0.12em;
      }

      .signal-step.is-active {
        background: var(--accent-subtle);
        color: var(--accent);
        box-shadow: inset 0 -2px var(--accent);
      }

      .signal-step.is-complete { color: var(--green); }
      .signal-step.is-complete span { color: var(--green); }

      .account-card { padding: clamp(22px, 4vw, 38px); }
      .account-card > * { position: relative; z-index: 1; }

      .account-card-heading,
      .management-card-header,
      .invitation-link-heading {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 20px;
      }

      .account-card-heading { margin-bottom: 28px; }
      .account-card-heading h2,
      .management-card-header h2,
      .role-guide h2,
      .status-copy h2 {
        margin-top: 5px;
        color: var(--text);
        font-size: clamp(1.3rem, 2vw, 1.7rem);
      }

      .coordinate-mark {
        color: var(--muted);
        font-family: var(--font-mono);
        font-size: 0.58rem;
        letter-spacing: 0.14em;
      }

      .form-stack { display: grid; gap: 22px; }
      .form-stack.compact { gap: 17px; }
      .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
      .form-field { min-width: 0; }

      .form-label {
        display: block;
        margin-bottom: 7px;
        color: var(--text-dim);
        font-family: var(--font-mono);
        font-size: 0.68rem;
        font-weight: 600;
        letter-spacing: 0.04em;
      }

      .form-control {
        width: 100%;
        min-height: 44px;
        padding: 10px 12px;
        appearance: none;
        border: 1px solid var(--border-light);
        border-radius: var(--radius);
        outline: none;
        background: var(--bg-input);
        color: var(--text);
        font: inherit;
        transition: border-color var(--transition-fast), box-shadow var(--transition-fast), background var(--transition-fast);
      }

      .form-control:hover { border-color: #44443f; }
      .form-control:focus {
        border-color: var(--accent);
        background: #151519;
        box-shadow: 0 0 0 3px var(--accent-glow);
      }

      .form-control[aria-invalid="true"] { border-color: var(--red); }
      .form-control::placeholder { color: #55554d; }
      .form-control[readonly] { color: var(--text-dim); cursor: text; }

      .form-select {
        padding-right: 38px;
        background-image: linear-gradient(45deg, transparent 50%, var(--muted) 50%), linear-gradient(135deg, var(--muted) 50%, transparent 50%);
        background-position: calc(100% - 16px) 18px, calc(100% - 11px) 18px;
        background-size: 5px 5px, 5px 5px;
        background-repeat: no-repeat;
      }

      .form-control-sm { min-height: 34px; padding: 6px 30px 6px 9px; font-size: 0.72rem; }

      .form-hint,
      .account-footnote,
      .link-expiry {
        color: var(--muted);
        font-size: 0.72rem;
        line-height: 1.5;
      }

      .form-hint { margin-top: 6px; }

      .field-errors {
        min-height: 0;
        margin-top: 5px;
        color: var(--red);
        font-size: 0.74rem;
      }

      .field-errors p + p { margin-top: 3px; }

      .form-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        margin-top: 30px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
      }

      .form-footer p { max-width: 440px; color: var(--muted); font-size: 0.74rem; }
      .btn-block { width: 100%; margin-top: 18px; }
      .btn-sm { padding: 7px 10px; font-size: 0.66rem; }

      .status-panel {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: 22px;
        border-left: 2px solid var(--amber);
      }

      .status-panel.status-ready { border-left-color: var(--green); }
      .status-panel.status-failed { border-left-color: var(--red); }

      .status-emblem {
        width: 54px;
        height: 54px;
        display: grid;
        place-items: center;
        border: 1px solid var(--border-light);
        border-radius: 50%;
        color: var(--amber);
        background: var(--bg-elevated);
        font-family: var(--font-mono);
        font-size: 1.25rem;
      }

      .status-ready .status-emblem { color: var(--green); border-color: rgba(142, 166, 122, 0.4); }
      .status-failed .status-emblem { color: var(--red); border-color: rgba(201, 106, 106, 0.4); }
      .status-copy > p:not(.account-kicker) { max-width: 620px; margin-top: 10px; color: var(--text-dim); }
      .status-copy code,
      .organization-slug { color: var(--teal); font-family: var(--font-mono); font-size: 0.78em; }
      .status-detail { padding: 10px 12px; border-left: 2px solid var(--red); background: var(--red-glow); }
      .account-actions { display: flex; align-items: center; flex-wrap: wrap; gap: 12px; margin-top: 20px; }
      .account-footnote { margin-top: 14px; text-align: center; }

      .status-chip,
      .role-badge,
      .delivery-state,
      .you-badge,
      .link-ready-mark {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        font-family: var(--font-mono);
        font-size: 0.61rem;
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
      }

      .status-chip {
        gap: 8px;
        padding: 6px 9px;
        border: 1px solid var(--border-light);
        border-radius: var(--radius-sm);
        color: var(--text-dim);
      }

      .status-chip .status-dot,
      .delivery-state .status-dot {
        width: 6px;
        height: 6px;
        background: currentColor;
      }

      .status-chip .status-dot::after,
      .delivery-state .status-dot::after { display: none; }
      .status-chip.status-pending { color: var(--amber); }
      .status-chip.status-accepted { color: var(--green); }
      .status-chip.status-expired,
      .status-chip.status-revoked { color: var(--red); }

      .invitation-details {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
      }

      .invitation-details > div { padding: 16px; border-bottom: 1px solid var(--border); }
      .invitation-details > div:nth-child(odd) { border-right: 1px solid var(--border); }
      .invitation-details > div:nth-last-child(-n + 2) { border-bottom: 0; }
      .invitation-details dt { color: var(--muted); font-family: var(--font-mono); font-size: 0.61rem; letter-spacing: 0.07em; text-transform: uppercase; }
      .invitation-details dd { margin-top: 5px; color: var(--text-dim); font-size: 0.84rem; overflow-wrap: anywhere; }

      .role-badge {
        padding: 4px 7px;
        border: 1px solid var(--border-light);
        border-radius: var(--radius-sm);
        color: var(--text-dim);
        background: var(--bg-elevated);
      }

      .role-badge.role-owner { color: var(--accent); border-color: rgba(212, 120, 92, 0.35); background: var(--accent-subtle); }
      .role-badge.role-admin { color: var(--teal); border-color: rgba(90, 138, 138, 0.35); background: var(--teal-glow); }
      .role-badge.role-member { color: var(--green); border-color: rgba(142, 166, 122, 0.3); background: var(--green-glow); }

      .invitation-decision {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 18px;
        margin-top: 24px;
        padding-top: 24px;
        border-top: 1px solid var(--border);
      }

      .decision-copy { display: flex; align-items: flex-start; gap: 12px; max-width: 560px; }
      .decision-copy h3 { color: var(--text); font-size: 1rem; }
      .decision-copy p { margin-top: 4px; color: var(--muted); font-size: 0.78rem; line-height: 1.5; }

      .decision-icon {
        width: 30px;
        height: 30px;
        display: grid;
        flex: 0 0 auto;
        place-items: center;
        border: 1px solid var(--border-light);
        border-radius: 50%;
        color: var(--text-dim);
        font-family: var(--font-mono);
      }

      .decision-success .decision-icon { color: var(--green); border-color: rgba(142, 166, 122, 0.4); }
      .decision-warning .decision-icon { color: var(--amber); border-color: rgba(201, 168, 106, 0.4); }
      .decision-danger .decision-icon { color: var(--red); border-color: rgba(201, 106, 106, 0.4); }
      .invitation-empty { padding-block: 72px; }

      .members-heading {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 30px;
        margin-bottom: 26px;
      }

      .members-heading .account-intro { margin-bottom: 0; }
      .members-heading .account-intro h1 { font-size: clamp(2.2rem, 4vw, 3.75rem); }

      .access-summary {
        display: grid;
        grid-template-columns: repeat(3, minmax(76px, 1fr));
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--bg-card);
      }

      .access-summary > div { min-width: 86px; padding: 13px 15px; border-right: 1px solid var(--border); }
      .access-summary > div:last-child { border-right: 0; }
      .access-summary strong { display: block; color: var(--text); font-family: var(--font-display); font-size: 1.15rem; text-transform: capitalize; }
      .access-summary span { display: block; margin-top: 2px; color: var(--muted); font-family: var(--font-mono); font-size: 0.56rem; letter-spacing: 0.07em; text-transform: uppercase; }

      .management-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
        gap: 18px;
        margin-bottom: 18px;
        align-items: start;
      }

      .role-guide dl { display: grid; gap: 0; margin: 22px 0 16px; }
      .role-guide dl > div { display: grid; grid-template-columns: 78px 1fr; gap: 12px; padding: 13px 0; border-bottom: 1px solid var(--border); }
      .role-guide dl > div:first-child { border-top: 1px solid var(--border); }
      .role-guide dd { color: var(--text-dim); font-size: 0.76rem; line-height: 1.45; }

      .invite-delivery-note {
        margin-top: 18px;
        padding: 10px 12px;
        border-left: 2px solid var(--amber);
        background: var(--amber-glow);
        color: var(--text-dim);
        font-size: 0.73rem;
        line-height: 1.5;
      }

      .invitation-link-reveal {
        margin-top: 22px;
        padding: 18px;
        border: 1px solid rgba(142, 166, 122, 0.35);
        border-radius: var(--radius);
        background: linear-gradient(145deg, var(--green-glow), rgba(20, 20, 24, 0.85));
        box-shadow: inset 3px 0 var(--green);
      }

      .invitation-link-heading { align-items: center; margin-bottom: 10px; }
      .invitation-link-heading h3 { margin-top: 3px; font-size: 1rem; }
      .invitation-link-reveal > p { color: var(--text-dim); font-size: 0.74rem; line-height: 1.5; }
      .invitation-link-reveal > .form-label { margin-top: 15px; }
      .link-ready-mark { padding: 4px 7px; border: 1px solid rgba(142, 166, 122, 0.35); border-radius: var(--radius-sm); color: var(--green); background: var(--green-glow); }
      .link-expiry { margin-top: 8px; font-family: var(--font-mono); }

      .copy-field { display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 8px; }
      .copy-field .form-control { font-size: 0.69rem; }
      .btn-copy { min-width: 96px; padding-inline: 14px; border-color: var(--green); background: var(--green); color: #10120f; }
      .btn-copy[data-copy-state="copied"] { border-color: var(--green); background: transparent; color: var(--green); }

      .management-card { margin-top: 18px; overflow: hidden; }
      .management-card-header { align-items: center; padding: 22px 24px 18px; border-bottom: 1px solid var(--border); }
      .management-card > * { position: relative; z-index: 1; }
      .table-scroll { width: 100%; overflow-x: auto; }
      .management-table { min-width: 760px; }
      .management-table th { padding: 12px 18px; background: rgba(15, 15, 18, 0.45); }
      .management-table td { padding: 15px 18px; vertical-align: middle; }
      .management-table tbody tr:last-child td { border-bottom: 0; }
      .actions-column { text-align: right !important; }
      .management-table td:last-child { text-align: right; }

      .member-identity { display: flex; align-items: center; gap: 10px; min-width: 220px; }
      .member-identity > span:nth-child(2) { min-width: 0; }
      .member-identity strong,
      .member-identity small { display: block; }
      .member-identity strong,
      .table-primary { color: var(--text); font-size: 0.8rem; font-weight: 600; }
      .member-identity small { margin-top: 2px; color: var(--muted); font-size: 0.7rem; }

      .member-avatar {
        width: 34px;
        height: 34px;
        display: grid !important;
        flex: 0 0 auto;
        place-items: center;
        border: 1px solid var(--border-light);
        border-radius: 50%;
        background: var(--bg-elevated);
        color: var(--accent);
        font-family: var(--font-display);
        font-weight: 700;
      }

      .you-badge { padding: 3px 6px; border: 1px solid var(--border-light); border-radius: var(--radius-sm); color: var(--muted); }
      .table-actions,
      .role-form { display: flex; align-items: center; justify-content: flex-end; gap: 7px; }
      .role-form .form-select { width: 98px; }
      .table-muted { color: var(--muted); font-family: var(--font-mono); font-size: 0.65rem; }
      .delivery-state { gap: 8px; color: var(--green); white-space: nowrap; }
      .compact-empty { padding-block: 30px; }

      @media (max-width: 1180px) {
        .organization-pill,
        .user-identity { display: none; }
        .header-primary { gap: 16px; }
      }

      @media (max-width: 900px) {
        .header-inner { align-items: stretch; flex-direction: column; padding-block: 11px; }
        .header-primary { width: 100%; }
        .primary-nav { flex: 1; }
        .header-meta { justify-content: flex-end; }
        .members-heading { align-items: flex-start; flex-direction: column; }
        .management-grid { grid-template-columns: 1fr; }
        .access-summary { width: 100%; }
      }

      @media (max-width: 640px) {
        .main { padding: 24px 16px 60px; }
        .header-inner { padding-inline: 16px; }
        .header-primary { align-items: flex-start; flex-direction: column; }
        .primary-nav { width: 100%; padding-bottom: 2px; }
        .header-meta { width: 100%; justify-content: space-between; }
        .header-meta .header-actions { display: none; }
        .header-button { padding-inline: 10px; }
        .account-intro::before { display: none; }
        .signal-rail { grid-template-columns: 1fr; }
        .signal-step { min-height: 40px; border-right: 0; border-bottom: 1px solid var(--border); }
        .signal-step:last-child { border-bottom: 0; }
        .form-grid,
        .invitation-details { grid-template-columns: 1fr; }
        .invitation-details > div,
        .invitation-details > div:nth-child(odd) { border-right: 0; border-bottom: 1px solid var(--border); }
        .invitation-details > div:nth-last-child(2) { border-bottom: 1px solid var(--border); }
        .invitation-details > div:last-child { border-bottom: 0; }
        .form-footer,
        .invitation-decision { align-items: stretch; flex-direction: column; }
        .form-footer .btn,
        .invitation-decision > .btn { width: 100%; }
        .status-panel { grid-template-columns: 1fr; }
        .status-emblem { width: 44px; height: 44px; }
        .access-summary { grid-template-columns: 1fr; }
        .access-summary > div { border-right: 0; border-bottom: 1px solid var(--border); }
        .access-summary > div:last-child { border-bottom: 0; }
        .copy-field { grid-template-columns: 1fr; }
        .btn-copy { width: 100%; }
      }

      @media (prefers-reduced-motion: reduce) {
        *, *::before, *::after {
          scroll-behavior: auto !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
          transition-duration: 0.01ms !important;
        }
      }
    </style>
    <meta name="csrf-token" content={get_csrf_token()} />
  </head>
  <body>
    <%= @inner_content %>
    <script defer src="/assets/app.js"></script>
    <script>
      (() => {
        document.addEventListener("click", async (event) => {
          const trigger = event.target instanceof Element
            ? event.target.closest("[data-copy-target]")
            : null
          if (!trigger) return

          const input = document.getElementById(trigger.dataset.copyTarget)
          const status = document.getElementById(trigger.dataset.copyStatus)
          if (!input) return

          const copyManually = () => {
            input.focus()
            input.select()
            return document.execCommand("copy")
          }

          try {
            if (navigator.clipboard && window.isSecureContext) {
              await navigator.clipboard.writeText(input.value)
            } else if (!copyManually()) {
              throw new Error("Clipboard unavailable")
            }

            trigger.dataset.copyState = "copied"
            trigger.textContent = "Copied"
            if (status) status.textContent = "Invitation URL copied to the clipboard."

            window.setTimeout(() => {
              if (!document.body.contains(trigger)) return
              trigger.dataset.copyState = ""
              trigger.textContent = trigger.dataset.copyLabel || "Copy URL"
            }, 2200)
          } catch (_error) {
            input.focus()
            input.select()
            if (status) status.textContent = "Select the invitation URL and copy it manually."
          }
        })
      })()
    </script>
  </body>
</html>
